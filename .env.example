# --- Required ---
# Postgres connection string (Neon or local). Example formats:
#   Neon:  postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#   Local: postgres://postgres:postgres@localhost:5432/a1_insurance
DATABASE_URL=

# 32+ random chars for signing Auth.js JWT sessions. Generate with:
#   openssl rand -base64 48
AUTH_SECRET=

# PII encryption + HMAC keys. MUST be 32-byte hex (64 hex chars each). Generate with:
#   openssl rand -hex 32
PII_ENC_KEY=
PII_HMAC_KEY=

# Optional public site URL for links/previews.
NEXT_PUBLIC_SITE_URL=

# Optional login notifications.
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
